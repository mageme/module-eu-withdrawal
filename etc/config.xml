<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <mageme_eu_withdrawal>
            <general>
                <enabled>0</enabled>
                <increment_prefix></increment_prefix>
                <default_contract_type>physical_goods</default_contract_type>
                <frontend_route>withdraw-contract</frontend_route>
            </general>
            <precontract>
                <enabled>1</enabled>
                <return_address></return_address>
                <display_in_checkout>1</display_in_checkout>
            </precontract>
            <eligibility>
                <preset_custom>0</preset_custom>
                <preset_perishable>0</preset_perishable>
                <preset_sealed_hygiene>0</preset_sealed_hygiene>
                <preset_sealed_av>0</preset_sealed_av>
                <digital>
                    <enabled>0</enabled>
                    <detect_product_types>downloadable,virtual</detect_product_types>
                    <custom_attribute_code>is_digital_content</custom_attribute_code>
                </digital>
            </eligibility>
            <withdrawal_window>
                <period_days>14</period_days>
                <delivery_status_code></delivery_status_code>
            </withdrawal_window>
            <digital_waiver>
                <enabled>0</enabled>
                <virtual_timer_enabled>0</virtual_timer_enabled>
                <enforce_on_api>1</enforce_on_api>
                <email>
                    <enabled>1</enabled>
                    <identity>general</identity>
                    <template>mageme_eu_withdrawal_digital_waiver_email_template</template>
                    <bcc_merchant></bcc_merchant>
                </email>
            </digital_waiver>
            <frontend>
                <buttons>
                    <button_label_step1>Withdraw from contract here</button_label_step1>
                    <button_label_step2>Confirm withdrawal</button_label_step2>
                </buttons>
                <placements>
                    <footer_link>1</footer_link>
                    <my_account_link>1</my_account_link>
                </placements>
                <return_reasons>
                    <reasons><![CDATA[{"r1":{"code":"changed_mind","label":"Changed my mind"},"r2":{"code":"wrong_size","label":"Wrong size or fit"},"r3":{"code":"defective","label":"Defective or damaged"},"r4":{"code":"not_as_described","label":"Not as described"}}]]></reasons>
                    <enable_other>1</enable_other>
                </return_reasons>
                <review>
                    <shipping_info_text>You'll receive a prepaid shipping label in the confirmation email.</shipping_info_text>
                    <return_policy_url>return-policy</return_policy_url>
                </review>
            </frontend>
            <admin_notifications>
                <new_request>
                    <enabled>0</enabled>
                    <template>mageme_eu_withdrawal_admin_notifications_new_request_template</template>
                    <recipients></recipients>
                </new_request>
            </admin_notifications>
            <notifications>
                <submitted>
                    <enabled>1</enabled>
                    <template>mageme_eu_withdrawal_notifications_submitted_template</template>
                    <bcc_merchant></bcc_merchant>
                </submitted>
                <approved>
                    <enabled>1</enabled>
                    <template>mageme_eu_withdrawal_notifications_approved_template</template>
                    <bcc_merchant></bcc_merchant>
                </approved>
                <denied>
                    <enabled>1</enabled>
                    <template>mageme_eu_withdrawal_notifications_denied_template</template>
                    <bcc_merchant></bcc_merchant>
                </denied>
                <cancelled_admin>
                    <enabled>1</enabled>
                    <template>mageme_eu_withdrawal_notifications_cancelled_admin_template</template>
                    <bcc_merchant></bcc_merchant>
                </cancelled_admin>
                <cancelled_self>
                    <enabled>1</enabled>
                    <template>mageme_eu_withdrawal_notifications_cancelled_self_template</template>
                    <bcc_merchant></bcc_merchant>
                </cancelled_self>
                <receipt>
                    <enabled>1</enabled>
                    <template>mageme_eu_withdrawal_notifications_receipt_template</template>
                    <bcc_merchant></bcc_merchant>
                    <retry_attempts>3</retry_attempts>
                    <alert_address></alert_address>
                </receipt>
                <branding>
                    <usp_1>
                        <usp_1_icon>truck</usp_1_icon>
                        <usp_1_title></usp_1_title>
                        <usp_1_subtitle></usp_1_subtitle>
                    </usp_1>
                    <usp_2>
                        <usp_2_icon>return</usp_2_icon>
                        <usp_2_title></usp_2_title>
                        <usp_2_subtitle></usp_2_subtitle>
                    </usp_2>
                    <usp_3>
                        <usp_3_icon>shield</usp_3_icon>
                        <usp_3_title></usp_3_title>
                        <usp_3_subtitle></usp_3_subtitle>
                    </usp_3>
                    <social>
                        <social_instagram></social_instagram>
                        <social_x></social_x>
                        <social_facebook></social_facebook>
                        <social_youtube></social_youtube>
                    </social>
                </branding>
            </notifications>
            <retention>
                <pii_retention_days>730</pii_retention_days>
                <hash_retention_days>2190</hash_retention_days>
            </retention>
            <!-- audit_log defaults moved to MageMe_EUWithdrawalAudit/etc/config.xml (phase-34). -->
        </mageme_eu_withdrawal>
        <recaptcha_frontend>
            <type_for>
                <mageme_eu_withdrawal_lookup/>
            </type_for>
        </recaptcha_frontend>
        <!-- sales_email defaults moved to MageMe_EUWithdrawalMagicLink/etc/config.xml (phase-35). -->
    </default>
</config>
