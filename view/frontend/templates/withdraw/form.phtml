/** @var \MageMe\EUWithdrawal\Block\Withdraw\Form $block */
/** @var \Magento\Framework\Escaper $escaper */
$formKey      = method_exists($block, 'getFormKey') ? $block->getFormKey() : '';
$finalizeUrl  = $block->getUrl('withdraw-contract/api/finalize');
$orderHistory = $block->getUrl('sales/order/history');
$indexUrl     = $block->getUrl('withdraw-contract');
$homeUrl      = $block->getUrl('');
$orderMeta    = $block->getChildBlock('order_meta');
$orderIncrement = $orderMeta instanceof \MageMe\EUWithdrawal\Block\Withdraw\OrderMeta
    ? $orderMeta->getOrderIncrementId()
    : '';
// All lines ineligible? Push flag down to the sidebar so it can swap the
// empty-state message for an explanatory notice.
$noEligibleItems = method_exists($block, 'hasAnyEligibleItem') && !$block->hasAnyEligibleItem();
$returnSummaryChild = $block->getChildBlock('return_summary');
if ($returnSummaryChild !== false) {
    $returnSummaryChild->setData('no_eligible_items', $noEligibleItems);
}

// Push pending-request map + cancel URL into item_selector so each row can
// render the inline status strip + cancel button.
$itemSelectorChild = $block->getChildBlock('item_selector');
if ($itemSelectorChild !== false && method_exists($block, 'getPendingRequestsByOrderItemId')) {
    $itemSelectorChild->setData('pending_requests', $block->getPendingRequestsByOrderItemId());
    $itemSelectorChild->setData('cancel_url', $block->getCancelActionUrl());
    $itemSelectorChild->setData('form_key_html', $block->getBlockHtml('formkey'));
}

// Collect per-item tax + shipping amounts for the JS sidebar so it can render
// the "Tax" row alongside Items/Shipping like the order-view totals block.
//
// Bootstrap emits the *raw* `taxAmount` (= order_item.tax_amount) and
// `qtyOrdered` rather than a pre-divided `unitTax` so that JS can replicate
// `RefundCalculator::calculate()` arithmetic exactly:
//
//     lineTax = roundHalfEven(qty * taxAmount / qtyOrdered, 4)
//
// Pre-dividing on the server (`unitTax = round(tax/ordered, 4)`) and then
// multiplying on the client (`qty * unitTax`) introduced 0.01-cent rounding
// drift between the displayed total and the value that RefundCalculator wrote
// to mm_eu_withdrawal_request. Emitting the un-divided pair lets the client
// run the same single-round formula the server does.
//
// eligibleItems[itemId] = { qty, taxAmount, qtyOrdered }
$shippingPaid   = 0.0;
$shippingTax    = 0.0;
$eligibleItems  = [];
$orderForMeta   = $orderMeta instanceof \MageMe\EUWithdrawal\Block\Withdraw\OrderMeta
    ? $orderMeta->getOrder()
    : null;
if ($itemSelectorChild instanceof \MageMe\EUWithdrawal\Block\Withdraw\ItemSelector) {
    $states = $itemSelectorChild->getStates() ?? [];
    foreach ($states as $s) {
        if (!$s->isEligible() || $s->remainingQty <= 0) {
            continue;
        }
        $oi = $orderForMeta?->getItemById($s->orderItemId);
        $rowTax = $oi !== null ? (float) $oi->getTaxAmount() : 0.0;
        $qtyOrdered = $oi !== null ? (float) $oi->getQtyOrdered() : 0.0;
        if ($qtyOrdered <= 0) {
            $qtyOrdered = $s->purchasedQty > 0 ? (float) $s->purchasedQty : 1.0;
        }
        $eligibleItems[(int) $s->orderItemId] = [
            'qty'        => (int) $s->remainingQty,
            'taxAmount'  => round($rowTax, 4, PHP_ROUND_HALF_EVEN),
            'qtyOrdered' => $qtyOrdered,
        ];
    }
    if ($orderForMeta !== null) {
        $shippingPaid = (float) $orderForMeta->getShippingAmount();
        $shippingTax  = (float) $orderForMeta->getShippingTaxAmount();
    }
}

// Compute the order-level gap so the JS sidebar mirrors RefundCalculator
// exactly. Any difference between grand_total and the item-field sum is an
// order-level adjustment (payment-method discount, gift card, custom total)
// that must be distributed proportionally in the refund preview.
$orderItemsBase = 0.0;
$orderItemsTax  = 0.0;
foreach (($orderForMeta?->getItems() ?? []) as $oi) {
    if ($oi->getParentItemId()) {
        continue;
    }
    $orderItemsBase += (float) $oi->getRowTotal() - (float) $oi->getDiscountAmount();
    $orderItemsTax  += (float) $oi->getTaxAmount();
}
$orderLevelGap = round(
    (float) ($orderForMeta?->getGrandTotal() ?? 0.0)
    - $orderItemsBase
    - $orderItemsTax
    - (float) ($orderForMeta?->getShippingAmount() ?? 0.0)
    - (float) ($orderForMeta?->getShippingTaxAmount() ?? 0.0),
    4, PHP_ROUND_HALF_EVEN,
);

// Inline Tabler-style stroke icons (CSP-safe, scale with currentColor).
$icon = static function (string $name, string $class = 'mm-eu-w-icon', int $size = 20): string {
    $paths = [
        'info' => '<circle cx="12" cy="12" r="9"/><path d="M12 11v5"/><circle cx="12" cy="8" r="1" fill="currentColor" stroke="none"/>',
        'package' => '<path d="M3 9l9-4 9 4v10l-9 4-9-4z"/><polyline points="3 9 12 13 21 9"/><line x1="12" y1="13" x2="12" y2="22"/>',
        'truck' => '<path d="M3 6h12v9H3z"/><path d="M15 10h4l2 3v2h-6"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/>',
        'card' => '<rect x="3" y="5" width="18" height="14" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="7" y1="15" x2="11" y2="15"/>',
        'mail' => '<rect x="3" y="5" width="18" height="14" rx="2"/><polyline points="3 7 12 13 21 7"/>',
        'calendar' => '<rect x="4" y="5" width="16" height="16" rx="2"/><line x1="16" y1="3" x2="16" y2="7"/><line x1="8" y1="3" x2="8" y2="7"/><line x1="4" y1="11" x2="20" y2="11"/>',
        'copy' => '<rect x="8" y="8" width="12" height="12" rx="2"/><path d="M16 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"/>',
        'check' => '<polyline points="5 13 9 17 19 7"/>',
        'check-circle' => '<circle cx="12" cy="12" r="9"/><polyline points="8 12 11 15 16 9"/>',
        'pin' => '<path d="M12 2a7 7 0 0 1 7 7c0 5-7 13-7 13S5 14 5 9a7 7 0 0 1 7-7z"/><circle cx="12" cy="9" r="2.5"/>',
    ];
    $inner = $paths[$name] ?? '';
    return sprintf(
        '<svg class="%s" viewBox="0 0 24 24" width="%d" height="%d" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">%s</svg>',
        htmlspecialchars($class, ENT_QUOTES, 'UTF-8'),
        $size,
        $size,
        $inner,
    );
};
