            // stacked under the item row when the customer has re-submitted.
            $strips = [];
        if ($badge !== null && $badge['tone'] === 'pending' && $pendingList !== []) {
            foreach ($pendingList as $info) {
                $strips[] = ['tone' => 'pending', 'info' => $info];
            }
        } elseif ($badge !== null) {
            $strips[] = ['tone' => $badge['tone'], 'info' => null];
        }
        ?>
        <?php foreach ($strips as $strip): ?>
            <?php $stripClass = 'mm-eu-w-item-strip mm-eu-w-item-strip--' . $strip['tone']; ?>
            <tr class="<?= $escaper->escapeHtmlAttr($stripClass) ?>">
                <td colspan="7">
                    <div class="mm-eu-w-item-strip-body">
                        <span class="mm-eu-w-item-strip-icon" aria-hidden="true">
                            <?php if ($strip['tone'] === 'done'): ?>
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="5 13 9 17 19 7"/></svg>
