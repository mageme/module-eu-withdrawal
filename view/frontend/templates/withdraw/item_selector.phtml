                            <?php else: ?>
                                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r="1" fill="currentColor" stroke="none"/></svg>
                            <?php endif; ?>
                        </span>
                        <span class="mm-eu-w-item-strip-text">
                            <?php if ($strip['tone'] === 'done'): ?>
                                <?= $escaper->escapeHtml(__('Already returned.')) ?>
                            <?php elseif ($strip['tone'] === 'pending' && $strip['info'] !== null): ?>
                                <?php
                                    $statusLabel = $strip['info']['status'] === 'pending'
                                        ? __('awaiting admin review')
                                        : __('awaiting confirmation');
                                ?>
                                <?= $escaper->escapeHtml(__(
                                    'Request %1 %2 (%3 item%4).',
                                    $strip['info']['incrementId'] ?: ('#' . $strip['info']['requestId']),
                                    $statusLabel,
                                    (int) $strip['info']['qty'],
                                    ((int) $strip['info']['qty']) === 1 ? '' : 's',
                                )) ?>
                            <?php elseif ($strip['tone'] === 'pending'): ?>
                                <?= $escaper->escapeHtml(__('Return request awaiting review.')) ?>
                            <?php else: ?>
                                <?= $escaper->escapeHtml($block->getExclusionLabel((string) $state->exclusionReason)) ?>
